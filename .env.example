# Jellyfin MCP Server — Environment Configuration
# Copy this file to .env and fill in your values.

# ── Jellyfin server ────────────────────────────────────────────────────────
JELLYFIN_URL=http://your-jellyfin-server:8096
JELLYFIN_TOKEN=your_api_token_here

# ── Mount path mappings ────────────────────────────────────────────────────
# Maps Linux paths (as Jellyfin reports them) to Windows UNC paths.
# Add one pair per mount point, numbered from 1.

MOUNT_1_LINUX=/mnt/usb1
MOUNT_1_WINDOWS=\\your-nas\usbshare1

MOUNT_2_LINUX=/mnt/video
MOUNT_2_WINDOWS=\\your-server\video

# MOUNT_3_LINUX=/mnt/usb2
# MOUNT_3_WINDOWS=\\your-server\usb2
